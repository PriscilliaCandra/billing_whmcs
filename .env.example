# SahabatAI Billing — contoh konfigurasi.
# Salin menjadi .env lalu sesuaikan. JANGAN commit .env yang berisi kredensial asli.
#
# CATATAN: server tidak memuat file .env otomatis (tanpa dependency dotenv).
# Nilai dibaca dari environment proses. Di lokal, default in-code sudah cocok
# dengan MySQL bawaan Laragon, jadi file ini terutama sebagai dokumentasi +
# acuan variabel yang perlu di-set di server produksi (systemd/pm2/panel hosting).

# ── Koneksi MySQL (database billing TERPISAH dari database `sahabatai`) ──
BILLING_DB_HOST=localhost
BILLING_DB_PORT=3306
BILLING_DB_USER=root
BILLING_DB_PASSWORD=
BILLING_DB_NAME=billing

# ── Server ──
# Port HTTP aplikasi billing (default 3400).
PORT=3400

# ── Di belakang reverse proxy (produksi, HTTPS) ──
# Set true HANYA jika ada reverse proxy TLS di depan yang mengeset header
# X-Forwarded-Proto. Ini membuat cookie sesi ditandai Secure saat request HTTPS.
# Biarkan kosong/false untuk akses HTTP lokal langsung.
TRUST_PROXY=false

# ── Demo ──
# Set true untuk menampilkan hint kredensial demo di halaman login (dev/internal saja).
SHOW_DEMO_HINTS=false

# ── SSO dari OmsetAI (login tanpa register ulang) + sinkron invoice CRM ──
# WAJIB SAMA PERSIS dengan JWT_SECRET di .env sahabatai-backend (repo TERPISAH).
# Dipakai utk verifikasi token umur pendek yang diterbitkan OmsetAI backend — billing
# tidak menandatangani token apa pun, cuma memvalidasi:
#   - GET /sso?token=...          (purpose="billing-sso")  → login tanpa register ulang.
#   - POST /api/crm-invoices      (purpose="invoice-sync") → invoice CRM masuk ke akun
#     Billing milik user yang login (cocok by email), dipanggil sisi OmsetAI (kill-switch
#     BILLING_SYNC_ENABLED di .env OmsetAI, default OFF).
# Kosong/tak di-set → keduanya nonaktif (fallback ke perilaku lama: register manual /
# invoice CRM tak tersinkron ke Billing — byte-identik).
JWT_SECRET=
